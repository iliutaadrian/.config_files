# File system
if command -v eza &>/dev/null; then
  alias ls='eza -lh --group-directories-first --icons=auto'   #@ List files (long, icons)
  alias lsa='ls -a'   #@ List all files incl. hidden
  alias lt='eza --tree --level=2 --long --icons --git'   #@ Tree view (2 levels)
  alias lta='lt -a'   #@ Tree view incl. hidden
else
  alias ls='ls -lh --color=auto'   #@ List files (long)
  alias lsa='ls -lah --color=auto'   #@ List all files incl. hidden
fi

if command -v fzf &>/dev/null; then
  alias ff="fzf --preview 'bat --style=numbers --color=always {}'"   #@ Fuzzy-find a file (with preview)
  alias eff='$EDITOR $(ff)'   #@ Fuzzy-find and open a file in editor
fi

if command -v zoxide &>/dev/null; then
  alias cd="zd"   #@ Smart cd (zoxide)
  zd() {   #@ Smart cd (zoxide jump)
    if [ $# -eq 0 ]; then
      builtin cd ~ && return
    elif [ -d "$1" ]; then
      builtin cd "$1"
    else
      z "$@" && printf "\U000F17A9 " && pwd || echo "Error: Directory not found"
    fi
  }
fi

# Directories
alias ..='cd ..'   #@ Go up one directory

# Tools
alias c='clear'   #@ Clear screen
alias x='exit 0'   #@ Exit shell
alias cheat="$HOME/config/scripts/cheatsheet.sh"   #@ Show this shortcuts cheatsheet
alias t='tmux attach || tmux new -As config -c ~/config'   #@ Attach tmux (or start config session)
if command -v claude &>/dev/null; then
  # Stable session id derived from repo + current branch, so each branch keeps its own Claude session
  _cx_sid() {
    local key h
    key="$(git rev-parse --show-toplevel 2>/dev/null):$(git rev-parse --abbrev-ref HEAD 2>/dev/null)"
    if command -v md5sum &>/dev/null; then h=$(printf '%s' "$key" | md5sum | cut -d' ' -f1); else h=$(printf '%s' "$key" | md5 -q); fi
    printf '%s-%s-4%s-8%s-%s' "${h:0:8}" "${h:8:4}" "${h:13:3}" "${h:17:3}" "${h:20:12}"
  }
  _cx() {  # $1 = env prefix (e.g. "IS_SANDBOX=1"), rest = args
    local env="$1"; shift
    if git rev-parse --abbrev-ref HEAD &>/dev/null; then
      local sid branch; sid=$(_cx_sid); branch=$(git rev-parse --abbrev-ref HEAD)
      setopt local_options null_glob
      # resume only if a session file exists AND holds a real message (stub files
      # from an unused --session-id start can't be resumed → "No conversation found")
      local found=( $HOME/.claude/projects/*/${sid}.jsonl )
      if (( ${#found} )) && grep -ql '"type":"user"' "${found[1]}" 2>/dev/null; then
        print -P "%F{cyan}cx%f ⤷ %F{yellow}${branch}%f · resuming session ${sid:0:8}"
        env $env claude --dangerously-skip-permissions --resume "$sid" "$@"
      else
        (( ${#found} )) && rm -f "${found[1]}"   # drop empty stub so --session-id can reuse the id
        print -P "%F{cyan}cx%f ⤷ %F{yellow}${branch}%f · new session ${sid:0:8}"
        env $env claude --dangerously-skip-permissions --session-id "$sid" "$@"
      fi
    else
      env $env claude --dangerously-skip-permissions --continue "$@" 2>/dev/null \
        || env $env claude --dangerously-skip-permissions "$@"
    fi
  }
  if [[ "$OSTYPE" == "darwin"* ]]; then
    cx() { _cx "" "$@"; }   #@ Claude, continue this branch's session here
    alias cxn='claude --dangerously-skip-permissions'   #@ Claude, new session
  else
    cx() { IS_SANDBOX=1 claude --dangerously-skip-permissions --continue "$@" 2>/dev/null || IS_SANDBOX=1 claude --dangerously-skip-permissions "$@"; }   #@ Claude, continue last session here
    alias cxn='IS_SANDBOX=1 claude --dangerously-skip-permissions'   #@ Claude, new session
  fi
fi
command -v lazygit &>/dev/null   && alias lg='lazygit'   #@ Open lazygit

if command -v nvim &>/dev/null; then
  n() { if [ "$#" -eq 0 ]; then command nvim . ; else command nvim "$@"; fi; }   #@ Open nvim (cwd if no args)
  nv() { nvim --server ~/.cache/nvim/server.pipe --remote "$@" 2>/dev/null || nvim "$@"; }   #@ Open file in existing nvim instance
fi

# Personal (macOS only)
if [[ "$OSTYPE" == "darwin"* ]]; then
  alias nz="nvim ~/config/zsh/aliases"   #@ Edit zsh aliases
  alias nt="nvim ~/config/zsh/init"   #@ Edit zsh init
fi

alias src="echo 'source ~/.zshrc' && source ~/.zshrc"   #@ Reload zsh config
