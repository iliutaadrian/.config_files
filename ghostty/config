# Ghostty config — ported from alacritty/alacritty.toml
# Docs: https://ghostty.org/docs/config/reference

# Same TERM as alacritty so tmux/ssh behave identically
term = xterm-256color

# Window (alacritty: padding 5/5, Buttonless, opacity 0.9, Maximized)
window-padding-x = 5
window-padding-y = 5
window-decoration = false
background-opacity = 0.9
maximize = true

# Font (alacritty: JetBrainsMono Nerd Font Mono, ExtraLight, 15pt)
# ExtraLight normal face is why alacritty looks thin — same here.
font-family = JetBrainsMono Nerd Font Mono
font-style = Light
font-style-bold = Bold
font-style-italic = Italic
font-style-bold-italic = Italic
font-size = 15

# Colors (alacritty [colors.*] verbatim)
background = #010b17
foreground = #c6b0d4
selection-foreground = #38ff9c
selection-background = #000000
palette = 0=#0b3b61
palette = 1=#f7768e
palette = 2=#52ffcf
palette = 3=#fff383
palette = 4=#1376f8
palette = 5=#c792ea
palette = 6=#ff5dd4
palette = 7=#15fca2

# URLs: cmd+click opens (builtin), no extra config needed
